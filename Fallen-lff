    for i=1,#o do
        r[#r+1]=t[o[i]] or ""
    end
    return table.concat(r)
end

local function __ad(s)
    local a,b=1,0
    for i=1,#s do
        a=(a+s:byte(i))%65521
        b=(b+a)%65521
    end
    return b*65536+a
end

local function __fail(n)
    if notify then
        pcall(function() notify("ECLIPZE loader error: "..tostring(n), "error") end)
    elseif warn then
        pcall(function() warn("ECLIPZE loader error: "..tostring(n)) end)
    end
    return nil
end

local function __mk(k)
    local s=0
    for i=1,#k do
        s=(s*131+k:byte(i)+i*17)%2147483647
    end
    if s<1000 then s=s+12345 end
    return function()
        s=(s*48271+12345)%2147483647
        return s%251
    end
end

local function __dec64(txt, abc)
    local m={}
    for i=1,#abc do
        m[abc:byte(i)]=i-1
    end
    local out={}
    local n=#txt
    local i=1
    while i<=n do
        local a=m[txt:byte(i)]
        local b=m[txt:byte(i+1)]
        if not a or not b then return nil end
        local c=nil
        local d=nil
        if i+2<=n then c=m[txt:byte(i+2)] end
        if i+3<=n then d=m[txt:byte(i+3)] end
        out[#out+1]=string.char(math.floor(a*4+math.floor(b/16))%256)
        if c then
            out[#out+1]=string.char(((b%16)*16+math.floor(c/4))%256)
        end
        if d then
            out[#out+1]=string.char(((c%4)*64+d)%256)
        end
        i=i+4
    end
    return table.concat(out)
end

local function __crypt(data,k)
    local kb={}
    for i=1,#k do kb[i]=k:byte(i) end
    local pr=__mk(k)
    local out={}
    local kl=#kb
    for i=1,#data do
        local v=data:byte(i)
        local x=(v-pr()-kb[((i-1)%kl)+1]-i*7)%256
        out[#out+1]=string.char(x)
    end
    return table.concat(out)
end

local function __join()
    local r={}
    for i=1,#__O do
        local p=__C[__O[i]]
        if not p then return nil end
        r[#r+1]=p
    end
    return table.concat(r)
end

local function __noise(x)
    local sx=tostring(x or "")
    local n=0
    for i=1,#sx do n=(n*33+sx:byte(i))%99991 end
    return n
end
if __noise(__TRAP)==-1 then return __fail("trap") end

local __outer=__join()
if not __outer or #__outer~=__L0 then return __fail("chunk") end

local __mid=__dec64(__outer,__A0)
if not __mid then return __fail("b64a") end
__mid=__crypt(__mid,__cat_piece(__K0P,__K0O))
if #__mid~=__L1 or __ad(__mid)~=__H0 then return __fail("mid") end

local __raw=__dec64(__mid,__A1)
if not __raw then return __fail("b64b") end
local __src=__crypt(__raw,__cat_piece(__K1P,__K1O))
if #__src~=__LP or __ad(__src)~=__HP then return __fail("payload") end

__R=nil; __C=nil; __O=nil; __outer=nil; __mid=nil; __raw=nil
local __loader=loadstring or load
if not __loader then return __fail("load") end
local __fn,__err=__loader(__src)
__src=nil
if not __fn then return __fail(__err or "compile") end
return __fn()
end
